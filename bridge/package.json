{
  "name": "pi-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Host-side bridge that exposes pi-agent sessions over WebSocket for the watchOS/iOS clients.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "dev": "node --watch --import tsx src/server.ts",
    "start": "node --import tsx src/server.ts",
    "test:client": "node --import tsx test/wsclient.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.6",
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.2.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
