diff --git a/src/client/src/api/base.ts b/src/client/src/api/base.ts
new file mode 100644
index 0000000..9d67f62
--- /dev/null
+++ b/src/client/src/api/base.ts
@@ -0,0 +1,26 @@
+// Runtime deployment base.
+//
+// PI WEB normally serves from the root origin ("/"). Behind Renku the session is proxied
+// under RENKU_BASE_URL_PATH (e.g. "/sessions/<id>/") and that prefix is NOT stripped before
+// reaching us. The server templates the real prefix into <base href> in index.html, so every
+// relative URL — including Vite's hashed asset URLs — resolves against it. We read it back
+// through document.baseURI so REST and WebSocket URLs carry the prefix too. Do not read
+// location.host / hardcode "/api" anywhere else; route through the two helpers below.
+
+const deploymentBase = new URL(".", document.baseURI); // normalized; always ends in "/"
+
+/**
+ * Resolve an app path ("/api/…") against the deployment base.
+ * Idempotent: already-absolute URLs (http(s)://…) pass through unchanged, so it is safe to
+ * wrap a builder whose result may later be handed to request() (which also calls apiUrl()).
+ */
+export function apiUrl(path: string): string {
+  return new URL(path.replace(/^\/+/u, ""), deploymentBase).toString();
+}
+
+/** ws(s):// origin + base path, with NO trailing slash — callers append "/api/…". */
+export function webSocketBaseUrl(): string {
+  const url = new URL(deploymentBase.href);
+  url.protocol = url.protocol === "https:" ? "wss:" : "ws:";
+  return url.href.replace(/\/$/u, "");
+}
